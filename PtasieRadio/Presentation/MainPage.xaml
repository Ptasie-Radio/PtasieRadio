                                        <TransformGroup>
                                            <ScaleTransform ScaleY="-1" CenterY="12"/>
                                            <TranslateTransform Y="-5"/>
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                                <!-- hamburger.svg -->
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPointerOver"
                                         Value="True">
                                    <Setter TargetName="ellipse"
                                            Property="Fill"
                                            Value="#A494F9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Wyszukiwarka -->
                <Grid Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Width="600"
                                 Height="40"
                                 CornerRadius="20"
                                 Background="{StaticResource PrimaryColor}"
                                 BorderThickness="0"
                                 PlaceholderText="Wyszukaj..."
                                 Foreground="{StaticResource TextColor}"
                                 FontWeight="SemiBold"
                                 Padding="20,11,0,0"
                                 HorizontalContentAlignment="Left"
                                 VerticalContentAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="FocusVisualPrimaryBrush"
                                            Value="Transparent"/>
                                    <Setter Property="FocusVisualSecondaryBrush"
                                            Value="Transparent"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <Button Grid.Column="1"
                                Width="40"
                                Height="40"
                                Background="{StaticResource PrimaryColor}"
                                BorderThickness="0"
                                Padding="0"
                                CornerRadius="20">
                            <Path Width="24"
                                Height="24"
                                Stretch="Uniform"
                                Fill="{StaticResource IconColor}"
