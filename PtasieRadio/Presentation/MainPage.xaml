<Page x:Class="PtasieRadio.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:PtasieRadio.Presentation"
      xmlns:ue="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:i="using:Microsoft.Xaml.Interactivity"
      xmlns:ic="using:Microsoft.Xaml.Interactions.Core"
      NavigationCacheMode="Required">


    <Grid Background="{StaticResource PrimaryColor}">
        <Grid
            x:Name="RadioMainPage"
            Visibility="Visible">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Pasek wyszukiwania -->
            <RowDefinition Height="Auto"/> <!-- Pasek kategorii -->
            <RowDefinition Height="*"/>   <!-- Radia itp -->
            <RowDefinition Height="Auto"/> <!-- MiniPlayer -->
        </Grid.RowDefinitions>


            <!-- Górny pasek wyszukiwania -->
            <Grid Grid.Row="0"
                  Background="{StaticResource SecondaryColor}"
                  Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hamburger Menu z podświetleniem -->
                <Button Width="40"
                        Height="40"
                        Background="Transparent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="ellipse"
                                         Fill="Transparent"
                                         Width="40"
                                         Height="40"/>
                                <Path Width="24"
                                    Height="24"
                                    Stretch="Uniform"
                                    Fill="{StaticResource IconColor}"
                                    Data="M336 2619 c-72 -12 -135 -55 -173 -119 -28 -46 -33 -63 -33 -120 0 -117 61 -204 168 -242 54 -19 2350 -19 2404 0 112 40 173 132 166 251 -7 125 -86 210 -213 231 -73 12 -2248 11 -2319 -1z M310 1741 c-72 -23 -138 -79 -164 -143 -20 -48 -20 -148 0 -196 19 -47 67 -97 119 -125 l40 -22 1195 0 1195 0 40 22 c90 48 135 123 135 223 0 100 -45 175 -135 223 l-40 22 -1180 2 c-649 1 -1191 -2 -1205 -6z M333 870 c-82 -17 -144 -62 -179 -132 -22 -44 -26 -61 -22 -123 3 -59 9 -81 33 -121 38 -61 102 -101 180 -114 80 -13 2230 -13 2310 0 127 21 206 106 213 231 7 115 -44 197 -154 246 -37 17 -110 18 -1189 20 -632 0 -1169 -3 -1192 -7z">
