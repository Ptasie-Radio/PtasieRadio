                                <Path.RenderTransform>
                                    <ScaleTransform ScaleY="-1" CenterY="12"/>
                                </Path.RenderTransform>
                            </Path>
                            <!-- search.svg -->

                        </Button>
                    </Grid>
                </Grid>

                <!-- Ikona zębatki -->
                <Button Grid.Column="2"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        Command="{Binding NavigateCommand}"
                        Tapped="RackTappedEvent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="ellipse"
                                         Fill="Transparent"
                                         Width="40"
                                         Height="40"/>
