                            </Path.RenderTransform>
                        </Path>
                    <!-- shuffle.svg -->
                    </Button>
                    <Button Background="Transparent"
                            x:Name="MiniPlayButton"
                            Command="{Binding PlayRadioCommand}"
                            Tapped="PlayPauseButtonTappedEvent">
                        <Path Width="24"
                            Height="24"
                            Stretch="Uniform"
                            Fill="{StaticResource IconColor}"
                            Data="{Binding MiniPlayPauseButtonImage}"
                            x:Name="MiniPlayButtonImage">
                            <Path.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="-1" CenterY="12"/>
                        </TransformGroup>
                    </Path.RenderTransform> 
                           </Path>   
                    </Button>
<!-- tutaj trzeba fabiana mini_play.svg mini_pause.svg -->

                    <Button Background="Transparent"
                            x:Name="MiniHeartButton"
                            Tapped="HeartButtonTappedEvent">
                        <Path Width="24"
                            Height="24"
                            Stretch="Uniform"
                            Fill="{StaticResource IconColor}"
                            Data="M636 2809 c-268 -66 -496 -284 -584 -559 -136 -425 -8 -802 417
