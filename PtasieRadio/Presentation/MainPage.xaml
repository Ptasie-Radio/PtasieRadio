                                43 87 107 155 188 198 79 42 120 51 223 47 77 -3 97 -8 160 -39z">
                                    <Path.RenderTransform>
                                        <ScaleTransform ScaleY="-1" CenterY="12"/>
                                    </Path.RenderTransform>
                                </Path>

                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPointerOver"
                                         Value="True">
                                    <Setter TargetName="ellipse"
                                            Property="Fill"
                                            Value="#12101DFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Pasek kategorii -->

            <Grid Grid.Row="1"
                  Background="{StaticResource SecondaryColor}"
                  Padding="24,10,24,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="50">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
            <TextBlock Text="Główna"
                    Foreground="{StaticResource TextColor}"
                    FontSize="16"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"/>
                    <!-- Podkreślenie żeby info było na jakiej kategori jesteś -->
            <Rectangle Height="2"
                    Width="50"
                    Fill="{StaticResource TextColor}"
                    RadiusX="1"
                    RadiusY="1"
                    HorizontalAlignment="Center"/>
            </StackPanel>

        <TextBlock Text="Gatunek"
                   Foreground="Gray"
                   FontSize="16"/>
        <TextBlock Text="Kraj"
                   Foreground="Gray"
                   FontSize="16"/>
    </StackPanel>
</Grid>


            <!-- Sekcje główne -->
            <ScrollViewer Grid.Row="2">
                <StackPanel Padding="10"
                            Spacing="20">
                    <!-- Sekcja: Najczęściej Grane -->
                    <TextBlock Text="Najczęściej Grane"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,0,0,10"/>
                    <ScrollViewer x:Name="NajczesciejGraneScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled"
                                  ZoomMode="Disabled">
                        <StackPanel Orientation="Horizontal"
                                    ManipulationMode="None"
                                    x:Name="NajczesciejGranePanel"
                                    Spacing="20"
                                    Padding="20,0,0,0">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="PointerPressed">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStartCommand}"/>
                                </ic:EventTriggerBehavior>
                                <ic:EventTriggerBehavior EventName="PointerMoved">
                                    <ic:InvokeCommandAction Command="{Binding ScrollMoveCommand}"/>
                                </ic:EventTriggerBehavior>
                                <ic:EventTriggerBehavior EventName="PointerReleased">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStopCommand}"/>
                                </ic:EventTriggerBehavior>
                                <!-- inaczej sa bledy ze mozna dalej przesuwac mimo odklikniecia przycisku mysz -->
                                <ic:EventTriggerBehavior EventName="PointerCaptureLost">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStopCommand}"/>
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>
                            <!-- Powielone karty stacji dla testu przesuwania -->
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Sekcja: Popularne -->
                    <TextBlock Text="Popularne"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,10,0,10"/>
                    <ScrollViewer x:Name="PopularneScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled"
                                  ZoomMode="Disabled">
                        <StackPanel Orientation="Horizontal"
                                    ManipulationMode="None"
                                    x:Name="PopularnePanel"
                                    Spacing="20"
                                    Padding="20,0,0,0">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="PointerPressed">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStartCommand}"/>
                                </ic:EventTriggerBehavior>
                                <ic:EventTriggerBehavior EventName="PointerMoved">
                                    <ic:InvokeCommandAction Command="{Binding ScrollMoveCommand}"/>
                                </ic:EventTriggerBehavior>
                                <ic:EventTriggerBehavior EventName="PointerReleased">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStopCommand}"/>
                                </ic:EventTriggerBehavior>
                                <!-- inaczej sa bledy ze mozna dalej przesuwac mimo odklikniecia przycisku mysz -->
                                <ic:EventTriggerBehavior EventName="PointerCaptureLost">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStopCommand}"/>
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>
                            <!-- Powielone karty stacji dla testu przesuwania -->
                        </StackPanel>
                    </ScrollViewer>

                    <!--Własne-->
                    <TextBlock Text="Własne"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,20,0,10"/>
                    <ScrollViewer x:Name="WlasneScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled"
                                  ZoomMode="Disabled">
                        <StackPanel Orientation="Horizontal"
                                    x:Name="WlasnePanel"
                                    Spacing="20"
                                    Padding="20,0,0,0">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="PointerPressed">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStartCommand}"/>
                                </ic:EventTriggerBehavior>
                                <ic:EventTriggerBehavior EventName="PointerMoved">
                                    <ic:InvokeCommandAction Command="{Binding ScrollMoveCommand}"/>
                                </ic:EventTriggerBehavior>
                                <ic:EventTriggerBehavior EventName="PointerReleased">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStopCommand}"/>
                                </ic:EventTriggerBehavior>
                                <!-- inaczej sa bledy ze mozna dalej przesuwac mimo odklikniecia przycisku mysz -->
                                <ic:EventTriggerBehavior EventName="PointerCaptureLost">
                                    <ic:InvokeCommandAction Command="{Binding ScrollStopCommand}"/>
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                        </StackPanel>
                    </ScrollViewer>

                </StackPanel>
            </ScrollViewer>

            <!-- Dolny pasek odtwarzacza (zmieniony) -->
            <Grid x:Name="MiniPlayer"
                  Grid.Row="3"
                  Background="{StaticResource SecondaryColor}"
                  Padding="10"
                  Tapped="MiniPlayerTapped">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="40"
                            Height="40"
                            Background="{StaticResource PrimaryColor}"
                            CornerRadius="5">
                        <Image Width="30"
                               Height="30"
                               Stretch="Uniform"
                               Source="ms-appx:///Assets/Images/radio_placeholder.png"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0">
                        <TextBlock Text="SomaFM - PopTron"
                                   Foreground="{StaticResource TextColor}"
                                   FontSize="14"/>
                        <TextBlock Text="somafm.com, US"
                                   Foreground="Gray"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Grid.Column="2"
                            Spacing="10">
                    <Button Background="Transparent"
                            x:Name="MiniShuffleButton"
                            Tapped="ShuffleButtonTappedEvent">
                        <Path Width="24"
                            Height="24"
                            Stretch="Uniform"
                            Fill="{StaticResource IconColor}"
