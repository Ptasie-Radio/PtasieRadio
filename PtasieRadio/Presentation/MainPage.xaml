<Page x:Class="PtasieRadio.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:PtasieRadio.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">


    <Grid Background="#1C1B1F">
        <Grid
            x:Name="RadioMainPage"
            Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Górny pasek wyszukiwania -->
            <Grid Grid.Row="0"
                  Background="#1B2029"
                  Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hamburger Menu z podświetleniem -->
                <Button Width="40"
                        Height="40"
                        Background="Transparent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="ellipse"
                                         Fill="Transparent"
                                         Width="40"
                                         Height="40"/>
                                <Image Source="ms-appx:///Assets/Images/hamburger.png"
                                       Stretch="Uniform"
                                       Width="24"
                                       Height="24"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPointerOver"
                                         Value="True">
                                    <Setter TargetName="ellipse"
                                            Property="Fill"
                                            Value="#A494F9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Wyszukiwarka -->
                <Grid Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Width="600"
                                 Height="40"
                                 CornerRadius="20"
                                 Background="#1C1B1F"
                                 BorderThickness="0"
                                 PlaceholderText="Wyszukaj..."
                                 Foreground="White"
                                 FontWeight="SemiBold"
                                 Padding="20,11,0,0"
                                 HorizontalContentAlignment="Left"
                                 VerticalContentAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="FocusVisualPrimaryBrush"
                                            Value="Transparent"/>
                                    <Setter Property="FocusVisualSecondaryBrush"
                                            Value="Transparent"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <Button Grid.Column="1"
                                Width="40"
                                Height="40"
                                Background="#2a2a2e"
                                BorderThickness="0"
                                Padding="0"
                                CornerRadius="20">
                            <Image Source="ms-appx:///Assets/Images/search.png"
                                   Stretch="Uniform"
                                   Width="20"
                                   Height="20"/>
                        </Button>
                    </Grid>
                </Grid>

                <!-- Ikona zębatki -->
                <Button Grid.Column="2"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        Command="{Binding NavigateCommand}"
                        Tapped="RackTappedEvent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="ellipse"
                                         Fill="Transparent"
                                         Width="40"
                                         Height="40"/>
                                <Image Source="ms-appx:///Assets/Images/setting.png"
                                       Stretch="Uniform"
                                       Width="24"
                                       Height="24"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPointerOver"
                                         Value="True">
                                    <Setter TargetName="ellipse"
                                            Property="Fill"
                                            Value="#12101DFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Pasek kategorii -->

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,10"
                        Spacing="30">
                <TextBlock Text="Główna"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"/>
                <TextBlock Text="Gatunek"
                           Foreground="Gray"
                           FontSize="16"/>
                <TextBlock Text="Kraj"
                           Foreground="Gray"
                           FontSize="16"/>
            </StackPanel>

            <!-- Sekcje główne -->
            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="10"
                            Spacing="20">
                    <!-- Sekcja: Najczęściej Grane -->
                    <TextBlock Text="Najczęściej Grane"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,10"/>
                    <ScrollViewer x:Name="NajczesciejGraneScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled"
                                  ZoomMode="Disabled">
                        <ItemsControl ItemsSource="{Binding MostPlayedStations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="20"
                                                Padding="20,0,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="0,10,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.PlayRadioCommand, ElementName=PageRoot}"
                                            CommandParameter="{Binding}">
                                        <Button.Content>
                                            <StackPanel Width="100"
                                                        Spacing="5">
                                                <Border Background="#cccccc"
                                                        CornerRadius="20"
                                                        Width="100"
                                                        Height="100">
                                                    <Image Width="60"
                                                           Height="60"
                                                           Stretch="Uniform"
                                                           Source="{Binding ImagePath}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           TextAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Button.Content>
                                        <Button.Resources>
                                            <ResourceDictionary>
                                                <!-- Nadpisanie stylu przycisku, aby miał przezroczyste tło w stanie normalnym -->
                                                <SolidColorBrush x:Key="ButtonBackground"
                                                                 Color="Transparent"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                                 Color="#22FFFFFF"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                                 Color="#44FFFFFF"/>
                                            </ResourceDictionary>
                                        </Button.Resources>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>

                    <!-- Sekcja: Popularne -->
                    <TextBlock Text="Popularne"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,10"/>
                    <ScrollViewer x:Name="PopularneScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled"
                                  ZoomMode="Disabled">
                        <ItemsControl ItemsSource="{Binding PopularStations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="20"
                                                Padding="20,0,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="0,10,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            utu:CommandExtensions.Command="{Binding DataContext.PlayRadioCommand, ElementName=PageRoot}"
                                            utu:CommandExtensions.CommandParameter="{Binding}">
                                        <Button.Content>
                                            <StackPanel Width="100"
                                                        Spacing="5">
                                                <Border Background="#cccccc"
                                                        CornerRadius="20"
                                                        Width="100"
                                                        Height="100">
                                                    <Image Width="60"
                                                           Height="60"
                                                           Stretch="Uniform"
                                                           Source="{Binding ImagePath}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           TextAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Button.Content>
                                        <Button.Resources>
                                            <ResourceDictionary>
                                                <!-- Nadpisanie stylu przycisku, aby miał przezroczyste tło w stanie normalnym -->
                                                <SolidColorBrush x:Key="ButtonBackground"
                                                                 Color="Transparent"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                                 Color="#22FFFFFF"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                                 Color="#44FFFFFF"/>
                                            </ResourceDictionary>
                                        </Button.Resources>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </ScrollViewer>

            <!-- Dolny pasek odtwarzacza (zmieniony) -->
            <Grid x:Name="MiniPlayer"
                  Grid.Row="2"
                  Background="#1B2029"
                  Padding="10"
                  Tapped="MiniPlayerTapped">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="40"
                            Height="40"
                            Background="#cccccc"
                            CornerRadius="5">
                        <Image Width="30"
                               Height="30"
                               Stretch="Uniform"
                               Source="ms-appx:///Assets/Images/placeholder.png"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0">
                        <TextBlock Text="{Binding StationName}"
                                   Foreground="White"
                                   FontSize="14"/>
                        <TextBlock Foreground="Gray"
                                   FontSize="12">
                                <!-- co to ma być, bo ja nie wiem -->
                                <Run Text="somafm.com, "/>
                                <Run Text="{Binding StationCountry}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Grid.Column="2"
                            Spacing="10">
                    <Button Background="Transparent"
                            x:Name="MiniShuffleButton"
                            Tapped="ShuffleButtonTappedEvent">
                        <Image Source="ms-appx:///Assets/Images/shuffle.png"
                               Stretch="Uniform"
                               Width="20"
                               Height="20"/>
                    </Button>
                    <Button Background="Transparent"
                            x:Name="MiniPlayButton"
                            Command="{Binding PlayRadioCommand}"
                            Tapped="PlayPauseButtonTappedEvent">
                        <Image Source="{Binding MiniPlayPauseButtonImage}"
                               Stretch="Uniform"
                               Width="20"
                               Height="20"
                               x:Name="MiniPlayButtonImage"/>
                    </Button>
                    <Button Background="Transparent"
                            x:Name="MiniHeartButton"
                            Tapped="HeartButtonTappedEvent">
                        <Image Source="ms-appx:///Assets/Images/heart.png"
                               Stretch="Uniform"
                               Width="20"
                               Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
        <!--Koniec Kontenera z Mini Radiem-->


        <!-- /////////////////////////////////////Full Page//////////////////////////////////////////////////////////////////////////////// -->





        <!--Kontener na FullPage Radio-->
        <Grid utu:SafeArea.Insets="VisibleBounds"
              x:Name="RadioOverlay"
              Visibility="Collapsed"
              Background="#1C1B1F">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="HeightPlayPageGroup">
                    <VisualState x:Name="ShortestHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="0"
                                              MinWindowHeight="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Visibility"
                                    Value="Collapsed"/>
                            <Setter Target="Gif.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="ShorterHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="0"
                                              MinWindowHeight="320"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Gif.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="ShortHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="0"
                                              MinWindowHeight="380"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Gif.Visibility"
                                    Value="Collapsed"/>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="130"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="130"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NormalHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="190"
                                              MinWindowHeight="480"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <!-- <Setter Target="Gif.Visibility" Value="Collapsed"/> -->
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="140"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="140"/>
                            <!-- slidery powinny zmniejszac sie/zrobic slider jako menukontekstowe ale to problem na inny dzien -->
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NormalishHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="190"
                                              MinWindowHeight="500"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="170"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="170"/>
                            <!-- <Setter Target="Gif.Width"
                                    Value="90"/>
                            <Setter Target="Gif.Height"
                                    Value="90"/> -->
                            <!-- te slidery powinny miec inna grupe visualna ale to problem na inny dzien -->
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Default">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="540"
                                              MinWindowHeight="560"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="210"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="210"/>
                            <Setter Target="Gif.Width"
                                    Value="90"/>
                            <Setter Target="Gif.Height"
                                    Value="90"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="MediumHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="640"
                                              MinWindowHeight="720"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="280"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="280"/>
                            <Setter Target="Gif.Width"
                                    Value="100"/>
                            <Setter Target="Gif.Height"
                                    Value="100"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="TallHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="820"
                                             MinWindowHeight="850"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="380"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="380"/>
                            <Setter Target="Gif.Width"
                                    Value="110"/>
                            <Setter Target="Gif.Height"
                                    Value="110"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="930"
                                             MinWindowHeight="950"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="440"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="440"/>
                            <Setter Target="Gif.Width"
                                    Value="110"/>
                            <Setter Target="Gif.Height"
                                    Value="110"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
                <VisualStateGroup x:Name="WidthPlayPageGroup">
                    <VisualState x:Name="DefaultWidth">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="350"
                                             MinWindowHeight="400"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="CountryName.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SmallerWidth">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="CountryName.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SmallWidth">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="300"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="CountryName.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
                <VisualStateGroup x:Name="VolumeSliderGroup">
                    <VisualState x:Name="DefaultVolume">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="390"
                                             MinWindowHeight="600"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Soundbar.VerticalAlignment"
                                    Value="Center"/>
                            <Setter Target="SoundLevelSlider.Visibility"
                                    Value="Visible"/>
                            <Setter Target="MuteUnmuteButton.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SmallerVolume">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="390"
                                             MinWindowHeight="400"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SoundLevelSlider.Visibility"
                                    Value="Visible"/>
                            <Setter Target="MuteUnmuteButton.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NoVolume">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SoundLevelSlider.Visibility"
                                    Value="Collapsed"/>
                            <Setter Target="MuteUnmuteButton.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.RenderTransform>
                <TranslateTransform x:Name="RadioOverlayTransform"
                                    Y="700"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Nagłówek -->
                <RowDefinition Height="*"/>
                <!-- Główna zawartość -->
                <RowDefinition Height="Auto"/>
                <!-- Nawigacja na dole -->
            </Grid.RowDefinitions>

            <!-- Nagłówek -->
            <Grid Grid.Row="0"
                  x:Name="RootGrid"
                  Background="#0B048DFF"
                  Padding="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Strzałka w dół -->
                    <ColumnDefinition Width="*"/>
                    <!-- Tekst i flaga (wycentrowane) -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Trzy kropki -->
                </Grid.ColumnDefinitions>



                <!-- Strzałka w dół -->
                <Button x:Name="DownArrow"
                        Grid.Column="0"
                        Style="{StaticResource MaterialIconButtonStyle}"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Tapped="ArrowTapped">
                    <Image Source="ms-appx:///Assets/Images/arrow_down.png"
                           Width="20"
                           Height="20"
                           Stretch="Uniform"/>
                </Button>

                <!-- Tekst i flaga -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock x:Name="RadioName"
                               Text="{Binding StationName}"
                               Style="{StaticResource MaterialSubtitle1Style}"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <StackPanel x:Name="CountryPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="8">
                        <Image x:Name="CountryFlag"
                               Source="ms-appx:///Assets/Images/flag.png"
                               Width="16"
                               Height="16"
                               Stretch="Uniform"/>
                        <TextBlock x:Name="CountryName"
                                   Text="{Binding StationCountry}"
                                   Style="{StaticResource MaterialCaptionStyle}"
                                   Foreground="LightGray"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Trzy kropki (ikona menu) -->
                <Button x:Name="MenuIcon"
                        Grid.Column="2"
                        Style="{StaticResource MaterialIconButtonStyle}"
                        Width="40"
                        Height="40"
                        Padding="0">
                    <FontIcon Glyph=""
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="20"
                              Foreground="White"/>
                </Button>
            </Grid>

            <!-- soundbar -->
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        x:Name="Soundbar"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Spacing="24"
                        Margin="20, 0, 0, 20">

                <!-- sound slider -->
                <Slider x:Name="SoundLevelSlider"
                        Orientation="Vertical"
                        Width="20"
                        Height="200"
                        Margin="0, 0, 0, -20"
                        HorizontalAlignment="Center"
                        Value="{Binding Volume, Mode=TwoWay}"
                        ValueChanged="OnSoundLevelSliderValueChanged">
                </Slider>

                <!-- mute/unmute button -->
                <Button Style="{StaticResource MaterialIconButtonStyle}"
                        x:Name="MuteUnmuteButton"
                        Width="96"
                        Height="96"
                        HorizontalAlignment="Center"
                        Command="{Binding ToggleMuteCommand}">
                    <Button.Content>
                        <Image Source="{Binding MuteButtonImage}"
                               x:Name="MuteUnmuteButtonImage"
                               Width="48"
                               Height="48"
                               Stretch="Uniform"/>
                    </Button.Content>
                </Button>

            </StackPanel>

            <!-- 🔧 GŁÓWNA ZAWARTOŚĆ -->
            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="24">




                <!-- Placeholder -->
                <Border x:Name="PlaceholderBorder"
                        Width="70"
                        Height="70"
                        Background="{ThemeResource SurfaceBrush}"
                        Margin="0,20,0,0"
                        CornerRadius="8">
                    <Image Source="ms-appx:///Assets/Images/placeholder.png"
                           Stretch="UniformToFill"/>
                </Border>

                <!-- GIF -->
                <Image x:Name="Gif"
                       Source="ms-appx:///Assets/Images/animation.gif"
                       Width="50"
                       Height="50"
                       Stretch="Uniform"/>
            </StackPanel>
            <!-- Tekst -->
            <StackPanel Grid.Row="2">

                <TextBlock Text="Zespół - Tytuł"
                           Style="{StaticResource MaterialBody1Style}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>

                <!-- Przycisk odtwarzania -->
                <Button Style="{StaticResource MaterialIconButtonStyle}"
                        x:Name="PlayButton"
                        Width="96"
                        Height="96"
                        HorizontalAlignment="Center"
                        Command="{Binding PlayRadioCommand}"
                        Tapped="PlayPauseButtonTappedEvent">
                    <Button.Content>
                        <Image Source="{Binding PlayPauseButtonImage}"
                               x:Name="PlayButtonImage"
                               Width="48"
                               Height="48"
                               Stretch="Uniform"/>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>