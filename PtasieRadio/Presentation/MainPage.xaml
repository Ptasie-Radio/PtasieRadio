                                <TransformGroup>
                                    <ScaleTransform ScaleY="-1" CenterY="12"/>
                                    <TranslateTransform Y="-4"/>
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                        <!-- heart.svg -->

                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
        <!--Koniec Kontenera z Mini Radiem-->


        <!-- /////////////////////////////////////Full Page//////////////////////////////////////////////////////////////////////////////// -->





        <!--Kontener na FullPage Radio-->
        <Grid utu:SafeArea.Insets="VisibleBounds"
              x:Name="RadioOverlay"
              Visibility="Collapsed"
              Background="{StaticResource PrimaryColor}">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="HeightPlayPageGroup">
                    <VisualState x:Name="ShortestHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="0"
                                              MinWindowHeight="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Visibility"
                                    Value="Collapsed"/>
                            <Setter Target="Gif.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="ShorterHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="0"
                                              MinWindowHeight="320"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Gif.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="ShortHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="0"
                                              MinWindowHeight="380"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Gif.Visibility"
                                    Value="Collapsed"/>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="130"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="130"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NormalHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="190"
                                              MinWindowHeight="480"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <!-- <Setter Target="Gif.Visibility" Value="Collapsed"/> -->
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="140"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="140"/>
                            <!-- slidery powinny zmniejszac sie/zrobic slider jako menukontekstowe ale to problem na inny dzien -->
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NormalishHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="190"
                                              MinWindowHeight="500"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="170"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="170"/>
                            <!-- <Setter Target="Gif.Width"
                                    Value="90"/>
                            <Setter Target="Gif.Height"
                                    Value="90"/> -->
                            <!-- te slidery powinny miec inna grupe visualna ale to problem na inny dzien -->
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Default">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="540"
                                              MinWindowHeight="560"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="210"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="210"/>
                            <Setter Target="Gif.Width"
                                    Value="90"/>
                            <Setter Target="Gif.Height"
                                    Value="90"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="MediumHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger  MinWindowWidth="640"
                                              MinWindowHeight="720"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="280"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="280"/>
                            <Setter Target="Gif.Width"
                                    Value="100"/>
                            <Setter Target="Gif.Height"
                                    Value="100"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="TallHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="820"
                                             MinWindowHeight="850"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="380"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="380"/>
                            <Setter Target="Gif.Width"
                                    Value="110"/>
                            <Setter Target="Gif.Height"
                                    Value="110"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideHeight">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="930"
                                             MinWindowHeight="950"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="PlaceholderBorder.Width"
                                    Value="440"/>
                            <Setter Target="PlaceholderBorder.Height"
                                    Value="440"/>
                            <Setter Target="Gif.Width"
                                    Value="110"/>
                            <Setter Target="Gif.Height"
                                    Value="110"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
                <VisualStateGroup x:Name="WidthPlayPageGroup">
                    <VisualState x:Name="DefaultWidth">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="350"
                                             MinWindowHeight="400"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="CountryName.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SmallerWidth">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="CountryName.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SmallWidth">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="300"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="CountryName.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
                <VisualStateGroup x:Name="VolumeSliderGroup">
                    <VisualState x:Name="DefaultVolume">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="390"
                                             MinWindowHeight="600"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Soundbar.VerticalAlignment"
                                    Value="Center"/>
                            <Setter Target="SoundLevelSlider.Visibility"
                                    Value="Visible"/>
                            <Setter Target="MuteUnmuteButton.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SmallerVolume">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="390"
                                             MinWindowHeight="400"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SoundLevelSlider.Visibility"
                                    Value="Visible"/>
                            <Setter Target="MuteUnmuteButton.Visibility"
                                    Value="Visible"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NoVolume">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SoundLevelSlider.Visibility"
                                    Value="Collapsed"/>
                            <Setter Target="MuteUnmuteButton.Visibility"
                                    Value="Collapsed"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.RenderTransform>
                <TranslateTransform x:Name="RadioOverlayTransform"
                                    Y="700"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Nagłówek -->
                <RowDefinition Height="*"/>
                <!-- Główna zawartość -->
                <RowDefinition Height="Auto"/>
                <!-- Nawigacja na dole -->
            </Grid.RowDefinitions>

            <!-- Nagłówek -->
            <Grid Grid.Row="0"
                  x:Name="RootGrid"
                  Background="{StaticResource SecondaryColor}"
                  Padding="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Strzałka w dół -->
                    <ColumnDefinition Width="*"/>
                    <!-- Tekst i flaga (wycentrowane) -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Trzy kropki -->
                </Grid.ColumnDefinitions>



                <!-- Strzałka w dół -->
                <Button x:Name="DownArrow"
                        Grid.Column="0"
                        Style="{StaticResource MaterialIconButtonStyle}"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Tapped="ArrowTapped">
                    <Path Width="24"
                        Height="24"
                        Stretch="Uniform"
                        Fill="{StaticResource IconColor}"
                        Data="M530 7039 c-81 -6 -124 -20 -214 -68 -136 -72 -262 -230 -299 -376 -14 -52 -13 -289 0 -340 14 -53 40 -112 53 -120 5 -3 10 -13 10 -22 0 -8 14 -34 32 -57 46 -61 3914 -3930 3978 -3980 66 -52 135 -91 207 -118 78 -29 308 -29 386 0 72 27 141 66 207 118 64 50 3932 3919 3978 3980 18 23 32 49 32 57 0 9 4 19 10 22 13 8 50 93 50 115 0 29 11 50 26 50 11 0 14 25 14 125 0 100 -3 125 -14 125 -15 0 -26 21 -26 50 0 11 -16 54 -37 97 -29 62 -53 95 -122 163 -83 82 -124 109 -254 164 -54 23 -320 23 -374 0 -79 -34 -110 -49 -163 -83 -37 -23 -634 -613 -1780 -1758 -949 -947 -1732 -1723 -1740 -1723 -8 0 -791 776 -1740 1723 -1146 1145 -1743 1735 -1780 1758 -148 93 -239 114 -440 98z">        
                    <Path.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="-1" CenterY="12"/>
                            <TranslateTransform Y="-10"/>
                        </TransformGroup>
                    </Path.RenderTransform> 
                </Path>
                           <!-- arrow_down.svg -->
                </Button>

                <!-- Tekst i flaga -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock x:Name="RadioName"
                               Text="Nazwa radia"
                               Style="{StaticResource MaterialSubtitle1Style}"
                               Foreground="{StaticResource TextColor}"
                               HorizontalAlignment="Center"/>
                    <StackPanel x:Name="CountryPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="8">
                        <Image x:Name="CountryFlag"
                               Source="ms-appx:///Assets/Images/flag.png"
                               Width="16"
                               Height="16"
                               Stretch="Uniform"/>
                        <TextBlock x:Name="CountryName"
                                   Text="Kraj pochodzenia"
                                   Style="{StaticResource MaterialCaptionStyle}"
                                   Foreground="LightGray"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Trzy kropki (ikona menu) -->
                <Button x:Name="MenuIcon"
                        Grid.Column="2"
                        Style="{StaticResource MaterialIconButtonStyle}"
                        Width="40"
                        Height="40"
                        Padding="0">
                    <FontIcon Glyph=""
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="20"
                              Foreground="{StaticResource TextColor}"/>
                </Button>
            </Grid>

            <!-- soundbar -->
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        x:Name="Soundbar"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Spacing="24"
                        Margin="20, 0, 0, 20">

                <!-- sound slider -->
                <Slider x:Name="SoundLevelSlider"
                        Orientation="Vertical"
                        Width="20"
                        Height="200"
                        Margin="0, 0, 0, -20"
                        HorizontalAlignment="Center"
                        Value="{Binding Volume, Mode=TwoWay}"
                        Foreground="{StaticResource TextColor}"
                        Background="{StaticResource SecondaryColor}"
                        ValueChanged="OnSoundLevelSliderValueChanged">
                        <Slider.Resources>
        <SolidColorBrush x:Key="SliderThumbBackground" Color="{ThemeResource IconColor}" />
    </Slider.Resources>
                </Slider>

                <!-- mute/unmute button -->
                <Button Style="{StaticResource MaterialIconButtonStyle}"
                        x:Name="MuteUnmuteButton"
                        Width="96"
                        Height="96"
                        HorizontalAlignment="Center"
                        Command="{Binding ToggleMuteCommand}">
                    <Button.Content>
                        <Path  Data="{Binding MuteButtonImage}"
                               x:Name="MuteUnmuteButtonImage"
                               Width="48"
                               Height="48"
                               Stretch="Uniform"
                               Fill="{StaticResource IconColor}">
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleY="-1" CenterY="12"/>
                                    <TranslateTransform Y="12"/>
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                    </Button.Content>
                </Button>

            </StackPanel>

            <!-- 🔧 GŁÓWNA ZAWARTOŚĆ -->
            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="24">




                <!-- Placeholder -->
                <Border x:Name="PlaceholderBorder"
                        Width="70"
                        Height="70"
                        Background="{ThemeResource SurfaceBrush}"
                        Margin="0,20,0,0"
                        CornerRadius="8">
                    <Image Source="ms-appx:///Assets/Images/placeholder.png"
                           Stretch="UniformToFill"/>
                </Border>

                <!-- GIF -->
                <Image x:Name="Gif"
                       Source="ms-appx:///Assets/Images/animation.gif"
                       Width="50"
                       Height="50"
                       Stretch="Uniform"/>
            </StackPanel>
            <!-- Tekst -->
            <StackPanel Grid.Row="2">

                <TextBlock Text="Zespół - Tytuł"
                           Style="{StaticResource MaterialBody1Style}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>

                <!-- Przycisk odtwarzania -->
                <Button Style="{StaticResource MaterialIconButtonStyle}"
                        x:Name="PlayButton"
                        Width="96"
                        Height="96"
                        HorizontalAlignment="Center"
                        Command="{Binding PlayRadioCommand}"
                        Tapped="PlayPauseButtonTappedEvent">
                    <Button.Content>
                        <Path  Data="{Binding PlayPauseButtonImage}"
                               x:Name="PlayButtonImage"
                               Fill="{StaticResource IconColor}"
                               Width="48"
                               Height="48"
                               Stretch="Uniform">
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleY="-1" CenterY="12"/>
                                    <TranslateTransform Y="20"/>
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
