<Page x:Class="PtasieRadio.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:PtasieRadio.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

<Grid Background="#1C1B1F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Górny pasek wyszukiwania -->
<Grid Grid.Row="0" Background="#1B2029" Padding="10">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <!-- Hamburger Menu z podświetleniem -->
    <Button Width="40" Height="40" Background="Transparent">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Ellipse x:Name="ellipse" Fill="Transparent" Width="40" Height="40"/>
                    <Image Source="ms-appx:///Assets/Images/hamburger.png" Stretch="Uniform" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsPointerOver" Value="True">
                        <Setter TargetName="ellipse" Property="Fill" Value="#A494F9"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <!-- Wyszukiwarka -->
    <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Width="600"
                     Height="40"
                     CornerRadius="20"
                     Background="#1C1B1F"
                     BorderThickness="0"
                     PlaceholderText="Wyszukaj..."
                     Foreground="White"
                     FontWeight="SemiBold"
                     Padding="20,11,0,0"
                     HorizontalContentAlignment="Left"
                     VerticalContentAlignment="Center">
                <TextBox.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="FocusVisualPrimaryBrush" Value="Transparent"/>
                        <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Button Grid.Column="1"
                    Width="40"
                    Height="40"
                    Background="#2a2a2e"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="20">
                <Image Source="ms-appx:///Assets/Images/search.png" Stretch="Uniform" Width="20" Height="20"/>
            </Button>
        </Grid>
    </Grid>

    <!-- Ikona zębatki -->
    <Button Grid.Column="2" Width="40" Height="40" Background="Transparent">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Ellipse x:Name="ellipse" Fill="Transparent" Width="40" Height="40"/>
                    <Image Source="ms-appx:///Assets/Images/setting.png" Stretch="Uniform" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsPointerOver" Value="True">
                        <Setter TargetName="ellipse" Property="Fill" Value="#12101DFF"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>
</Grid>

<!-- Pasek kategorii -->

<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10" Spacing="30">
    <TextBlock Text="Główna" Foreground="White" FontSize="16" FontWeight="Bold"/>
    <TextBlock Text="Gatunek" Foreground="Gray" FontSize="16"/>
    <TextBlock Text="Kraj" Foreground="Gray" FontSize="16"/>
</StackPanel>

                <!-- Sekcje główne -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="10" Spacing="20">
                <!-- Sekcja: Najczęściej Grane -->
<TextBlock Text="Najczęściej Grane" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
<ScrollViewer x:Name="NajczesciejGraneScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" ZoomMode="Disabled">
    <StackPanel Orientation="Horizontal" Spacing="20" Padding="20,0,0,0">
        <!-- Powielone karty stacji dla testu przesuwania -->
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio A" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio B" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio C" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio D" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio E" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</ScrollViewer>

<!-- Sekcja: Popularne -->
<TextBlock Text="Popularne" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,10,0,10"/>
<ScrollViewer x:Name="PopularneScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" ZoomMode="Disabled">
    <StackPanel Orientation="Horizontal" Spacing="20" Padding="20,0,0,0">
        <!-- Powielone karty stacji dla testu przesuwania -->
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio F" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio G" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio H" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio I" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio J" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio K" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio L" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio M" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
        <StackPanel Width="100" Background="Transparent" Spacing="5">
            <Border Background="#cccccc" CornerRadius="20" Width="100" Height="100">
                <Image Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Radio N" TextAlignment="Center" FontSize="12" Foreground="White"/>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </StackPanel>
</ScrollViewer>

        <!-- Dolny pasek odtwarzacza (zmieniony) -->
        <Grid x:Name="MiniPlayer" Grid.Row="2" Background="#1B2029" Padding="10" Tapped="MiniPlayerTapped">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" Background="#cccccc" CornerRadius="5">
                    <Image Width="30" Height="30" Stretch="Uniform" Source="ms-appx:///Assets/Images/placeholder.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="10,0">
                    <TextBlock Text="SomaFM - PopTron" Foreground="White" FontSize="14"/>
                    <TextBlock Text="somafm.com, US" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2" Spacing="1">
                <Button Background="Transparent">
                    <Image Source="ms-appx:///Assets/Images/shuffle.png" Stretch="Uniform" Width="20" Height="20"/>
                </Button>
                <Button Background="Transparent" Name="playButton" Tapped="PlayPauseButtonTappedEvent">
                    <Image Source="ms-appx:///Assets/Images/mini_play.png" Stretch="Uniform" Width="20" Height="20" Name="playButtonImage"/>
                </Button>
                <Button Background="Transparent">
                    <Image Source="ms-appx:///Assets/Images/heart.png" Stretch="Uniform" Width="22" Height="22"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>



