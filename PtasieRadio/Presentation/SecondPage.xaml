                        Background="Transparent"
                        Command="{Binding NavigateToMainCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="ellipse"
                                         Fill="Transparent"
                                         Width="40"
                                         Height="40"/>
