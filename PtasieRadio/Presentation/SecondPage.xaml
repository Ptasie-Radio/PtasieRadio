                          HorizontalScrollBarVisibility="Disabled"
                          ZoomMode="Disabled"
                          VerticalScrollMode="Enabled"
                          Padding="0,0,16,0">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,20"
                        Padding="24"
                        Width="420"
                        Background="Transparent">
