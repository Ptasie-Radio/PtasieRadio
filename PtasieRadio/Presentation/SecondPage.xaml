                        <!-- Panel z ikoną i nazwą użytkownika -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="Auto"
                                    Spacing="8">
                            <Ellipse Width="72"
                                     Height="72">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding ProfileImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       FontSize="14"
                                       Foreground="{StaticResource TextColor}"
                                       TextAlignment="Center"/>
