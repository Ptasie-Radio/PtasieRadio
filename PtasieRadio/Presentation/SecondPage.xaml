                                                390 391 569 576 580 602 33 81 17 129 -73 221 -100 102 -162 127 -237 93z"/>
                                <!-- left_arrow.svg -->

                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPointerOver"
                                         Value="True">
                                    <Setter TargetName="ellipse"
                                            Property="Fill"
                                            Value="#12101DFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

