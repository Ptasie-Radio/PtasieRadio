<Page x:Class="PtasieRadio.Presentation.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:PtasieRadio.Presentation"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#1c1b1f">

    <Grid>
        <!-- Górny pasek z przyciskiem powrotu DO NAPRAWY!!!-->
        <Grid HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="20"
              Canvas.ZIndex="1">
            <Button Width="40"
                    Height="40"
                    Background="Transparent"
                    Command="{Binding NavigateToSecondCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ellipse"
                                     Fill="Transparent"
                                     Width="40"
                                     Height="40"/>
                            <Image Source="ms-appx:///Assets/Images/left-arrow.png"
                                   Width="24"
                                   Height="24"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPointerOver"
                                     Value="True">
                                <Setter TargetName="ellipse"
                                        Property="Fill"
                                        Value="#12101DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="420"
                        Padding="24"
                        Spacing="24">

                <!-- Obrazek + Nazwa i Opis obok siebie -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Obrazek jako przycisk wyboru zdjęcia -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="0"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                Tapped="OnSelectImageTapped">
                        <Button Width="180"
                                Height="150"
                                Padding="0"
                                BorderThickness="1"
                                Background="Transparent"
                                x:Name="SelectedImageButton">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <!-- <Image Source="ms-appx:///Assets/Images/placeholder.png" -->
                                        <Image Source="{Binding ProfileImage, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                               Stretch="Fill"
                                               x:Name="SelectedImage"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="Kliknij aby wybrać zdjęcie"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Nazwa i Opis w pionie -->
                    <StackPanel Grid.Column="2"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBox Header="Nazwa profilu"
                                 Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                 Width="180"
                                 Height="40"
                                 x:Name="NameTextBox"/>
                    </StackPanel>

                    <!-- Przycisk zapisu -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="2"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <!-- hover powinien byc red -->
                        <!-- <Button Content="Usuń profil"
                                Width="160"
                                Height="40"
                                HorizontalAlignment="Center"/> -->
                        <Button Content="Usuń profil"
                        Width="160"
                        Height="40"
                        HorizontalAlignment="Center"
                        Tapped="OnDeleteButtonTapped"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Grid.Row="2"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Content="Zapisz dane"
                                Width="160"
                                Height="40"
                                HorizontalAlignment="Center"
                                Tapped="OnSaveButtonTapped"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>