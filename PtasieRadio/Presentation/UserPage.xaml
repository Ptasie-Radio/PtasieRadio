<Page x:Class="PtasieRadio.Presentation.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:PtasieRadio.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      Background="{StaticResource PrimaryColor}"
      mc:Ignorable="d">

    <Grid>
        <!-- Górny pasek z przyciskiem powrotu -->
        <Grid HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="20"
              Canvas.ZIndex="1">
            <Button Width="40"
                    Height="40"
                    Background="Transparent"
                    Command="{Binding NavigateToSecondCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ellipse"
                                     Fill="Transparent"
                                     Width="40"
                                     Height="40"/>
                            <Path Width="24"
                                  Height="24"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{StaticResource IconColor}"
                                  Data="M2055 2986 c-41 -19 -1411 -1394 -1425 -1429 -14 -40 -13 -82 5 -125
                                                21 -50 1369 -1396 1419 -1417 79 -33 137 -11 233 87 88 89 110 149 79 221
                                                -8 19 -247 266 -580 599 -311 312 -566 571 -566 575 0 4 254 262 565 573
                                                390 391 569 576 580 602 33 81 17 129 -73 221 -100 102 -162 127 -237 93z"/>
                            <!-- left_arrow.svg -->

                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPointerOver"
                                     Value="True">
                                <Setter TargetName="ellipse"
                                        Property="Fill"
                                        Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="460"
                        Padding="24"
                        Spacing="24">

                <!-- Obrazek + Nazwa i Opis obok siebie -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Obrazek jako przycisk wyboru zdjęcia -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="0"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                Tapped="OnSelectImageTapped">
                        <Button Width="180"
                                Height="150"
                                Padding="0"
                                BorderThickness="1"
                                Background="Transparent"
                                x:Name="SelectedImageButton">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <!-- <Image Source="ms-appx:///Assets/Images/placeholder.png" -->
                                        <Image Source="{Binding ProfileImage, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                               Stretch="Uniform"
                                               x:Name="SelectedImage"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="Kliknij aby wybrać zdjęcie"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextColor}"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Nazwa i Opis w pionie -->
                    <StackPanel Grid.Column="2"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBox Header="Nazwa profilu"
                                 PlaceholderText="Wprowadź nazwę profilu"
                                 Foreground="{StaticResource TextColor}"
                                 Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                 BorderBrush="{StaticResource IconColor}"
                                 Width="220"
                                 Height="40"
                                 x:Name="NameTextBox">
                            <TextBox.PlaceholderForeground>
                                <SolidColorBrush Color="{Binding Color, Source={StaticResource IconColor}}" Opacity="0.6"/>
                            </TextBox.PlaceholderForeground>
                        </TextBox>

                                 
                    </StackPanel>

                    <!-- Przycisk zapisu -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="2"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <!-- hover powinien byc red -->
                        <!-- <Button Content="Usuń profil"
                                Width="160"
                                Height="40"
                                HorizontalAlignment="Center"/> -->
                        <Button Content="Usuń profil"
                                Width="160"
                                Height="40"
                                Background="{StaticResource SecondaryColor}"
                                Foreground="{StaticResource TextColor}"
                                HorizontalAlignment="Center"
                                Tapped="OnDeleteButtonTapped"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Grid.Row="2"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Content="Zapisz dane"
                                Width="160"
                                Height="40"
                                Background="{StaticResource SecondaryColor}"
                                Foreground="{StaticResource TextColor}"
                                HorizontalAlignment="Center"
                                Tapped="OnSaveButtonTapped"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>